# Copiá este archivo como .env.local (para probar en tu compu)
# y cargá EXACTAMENTE las mismas variables en Vercel (Settings > Environment Variables).

# --- Supabase (base de datos donde se guardan las respuestas) ---
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_secreta

# --- Token secreto del enlace de la encuesta ---
# El enlace que vas a compartir será:  https://TU-SITIO/s/EL_TOKEN
# Poné algo largo y difícil de adivinar. Si lo cambiás, el enlace viejo deja de funcionar.
SURVEY_ACCESS_TOKEN=cambia-esto-por-algo-largo-y-secreto-2027

# --- Acceso al panel privado (solo vos) ---
# Con esta contraseña entrás a  https://TU-SITIO/admin
ADMIN_PASSWORD=pone-una-contrasena-fuerte

# Secreto interno para firmar la sesión del panel (cualquier texto largo).
APP_SECRET=otro-texto-largo-aleatorio-cualquiera
